AI_GATEWAY_API_KEY=your_key_here
AI_GATEWAY_MODEL=google/gemini-3-flash

# Optional outbound agent hooks. Set ONE of the two backends below.
# If HERMES_API_URL is set it takes precedence over OPENCLAW_HOOKS_URL.

# Hermes API Server (preferred): enable API_SERVER_ENABLED in ~/.hermes/.env,
# then run `hermes gateway`. Default port is 8642. The route will POST to
# `${HERMES_API_URL}/v1/runs` with the configured session id.
# HERMES_API_URL=http://127.0.0.1:8642
# HERMES_API_KEY=change-me-local-dev
# HERMES_KICKR_SESSION_ID=kickr-local-coach

# OpenClaw: configure with hooks.enabled=true and a mapped /hooks/kickr endpoint.
OPENCLAW_HOOKS_URL=http://127.0.0.1:18789/hooks/kickr
OPENCLAW_HOOKS_TOKEN=e3a19b0e0dd2aa390da43466df709d563a0beb3fb0e30dd984ea87c992ace147
