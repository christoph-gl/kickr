# ==============================================================================
# KICKR Core 2 Web Controller Configuration (OpenRouter)
# ==============================================================================
# Copy to `.env.local` and replace placeholders with real values.
# Do not commit `.env.local` — it is gitignored.

# Shared OpenRouter API Key (Required for all AI features)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
# Default model used for chat, live coach, workout builder, and ride summaries
LLM_CALLS_MODEL=google/gemini-3.5-flash

# Multimodal model used for workout screenshot extraction
WORKOUT_IMAGE_EXTRACTOR_MODEL=google/gemini-3.5-flash

# Model used for Text-to-Speech (TTS)
GROK_TTS_MODEL=x-ai/grok-voice-tts-1.0
GROK_TTS_VOICE_ID=alloy

# Optional per-lane overrides (leave commented out to use default model/key)
# LIVE_COACH_MODEL=google/gemini-3.5-flash
# LIVE_COACH_TIMEOUT_MS=8000
# WORKOUT_BUILDER_MODEL=google/gemini-3.5-flash
# RIDE_SUMMARY_MODEL=google/gemini-3.5-flash

# Legacy fallbacks (optional; OpenRouter vars above are preferred)
# LLM_CALLS_API_KEY=
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_MODEL=
# WORKOUT_IMAGE_EXTRACTOR_API_KEY=
# LIVE_COACH_API_KEY=
# XAI_API_KEY=

# ==============================================================================
# Outbound Agent Hooks Configuration
# ==============================================================================
# Set exactly ONE of the two backends below (Hermes takes precedence).

# 1. Hermes API Server: Enable API_SERVER_ENABLED in ~/.hermes/.env,
# then run `hermes gateway`. Default port is 8642.
HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=change-me-local-dev
HERMES_KICKR_SESSION_ID=kickr-local-coach

# 2. OpenClaw: Configure with hooks.enabled=true and a mapped /hooks/kickr endpoint.
# OPENCLAW_HOOKS_URL=http://127.0.0.1:18789/hooks/kickr
# OPENCLAW_HOOKS_TOKEN=your-openclaw-hooks-token-here

# Optional: Override the URL agents should call back to when queueing commands.
# AGENT_CALLBACK_BASE_URL=http://localhost:3000
# AGENT_COMMAND_TOKEN=your-agent-command-token-here
