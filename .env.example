# Shared text / non-image LLM calls (live coach, workout builder, ride summaries, etc.).
# Use an AI SDK / Vercel AI Gateway-compatible key and a fast model.
LLM_CALLS_API_KEY=your_llm_api_key_here
LLM_CALLS_MODEL=google/gemini-3-flash

# Optional per-lane overrides (fall back to LLM_CALLS_* then AI_GATEWAY_*).
# LIVE_COACH_API_KEY=your_fast_llm_api_key_here
# LIVE_COACH_MODEL=google/gemini-3-flash
# LIVE_COACH_TIMEOUT_MS=3500

# WORKOUT_BUILDER_API_KEY=your_workout_builder_llm_api_key_here
# WORKOUT_BUILDER_MODEL=google/gemini-3-flash

# RIDE_SUMMARY_API_KEY=your_post_ride_summary_llm_api_key_here
# RIDE_SUMMARY_MODEL=google/gemini-3-flash

# Required only for screenshot/image-to-workout extraction (multimodal model).
WORKOUT_IMAGE_EXTRACTOR_API_KEY=your_image_capable_ai_api_key_here
WORKOUT_IMAGE_EXTRACTOR_MODEL=google/gemini-3-flash

# Optional outbound agent hooks. Set ONE of the two backends below.
# If HERMES_API_URL is set it takes precedence over OPENCLAW_HOOKS_URL.

# Hermes API Server (preferred): enable API_SERVER_ENABLED in ~/.hermes/.env,
# then run `hermes gateway`. Default port is 8642. The route will POST to
# `${HERMES_API_URL}/v1/runs` with the configured session id.
# HERMES_API_URL=http://127.0.0.1:8642
# HERMES_API_KEY=change-me-local-dev
# HERMES_KICKR_SESSION_ID=kickr-local-coach

# OpenClaw: configure with hooks.enabled=true and a mapped /hooks/kickr endpoint.
# OPENCLAW_HOOKS_URL=http://127.0.0.1:<openclaw-port>/hooks/kickr
# OPENCLAW_HOOKS_TOKEN=replace-with-dedicated-hook-token

# Optional: override the URL agents should call back to when queueing commands.
# Usually leave unset; set only if the forwarded request URL is not reachable
# from Hermes/OpenClaw.
# AGENT_CALLBACK_BASE_URL=http://localhost:3000
